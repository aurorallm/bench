{
  "$schema": "https://www.getbifrost.ai/schema",
  "providers": {
    "openai": {
      "keys": [
        {
          "name": "bench-key",
          "value": "sk-bench-test-key",
          "models": [
            "*"
          ],
          "weight": 1
        }
      ],
      "network_config": {
        "base_url": "http://127.0.0.1:9099",
        "default_request_timeout_in_seconds": 120
      }
    }
  },
  "config_store": {
    "enabled": false
  },
  "client": {
    "enable_logging": false,
    "disable_content_logging": true
  },
  "logs_store": {
    "enabled": false,
    "type": "sqlite"
  }
}
